[mysqld]

# ─── Connection & Threading ───────────────────────────────────────────────────
# max_connections and innodb_buffer_pool_size are set via .env (see mysql.yml)
thread_cache_size        = 128
thread_stack             = 256K
back_log                 = 512

# ─── InnoDB Buffer Pool ───────────────────────────────────────────────────────
innodb_buffer_pool_instances = 4
innodb_buffer_pool_dump_at_shutdown = 1
innodb_buffer_pool_load_at_startup  = 1

# ─── InnoDB Logging (MySQL 8.0.30+ uses innodb_redo_log_capacity) ─────────────
innodb_redo_log_capacity     = 536870912
innodb_log_buffer_size       = 64M
# 2 = flush once/sec — best throughput, minimal risk (OS crash only)
innodb_flush_log_at_trx_commit = 2

# ─── InnoDB I/O ───────────────────────────────────────────────────────────────
innodb_flush_method          = O_DIRECT
innodb_file_per_table        = 1
innodb_io_capacity           = 2000
innodb_io_capacity_max       = 4000
innodb_read_io_threads       = 8
innodb_write_io_threads      = 8
innodb_stats_on_metadata     = 0

# ─── Query & Sort Memory ──────────────────────────────────────────────────────
tmp_table_size               = 64M
max_heap_table_size          = 64M
sort_buffer_size             = 4M
join_buffer_size             = 4M
read_rnd_buffer_size         = 4M

# ─── Networking ───────────────────────────────────────────────────────────────
max_allowed_packet           = 64M
skip_name_resolve            = 1

# ─── Character Set ────────────────────────────────────────────────────────────
character_set_server         = utf8mb4
collation_server             = utf8mb4_unicode_ci

# ─── Slow Query Log ───────────────────────────────────────────────────────────
slow_query_log               = 1
slow_query_log_file          = /var/lib/mysql/slow.log
long_query_time              = 1

[client]
default-character-set        = utf8mb4
