{
  "bookmark_bar": {
    "show_on_all_tabs": false
  },
  "signin": {
    "allowed": false,
    "allowed_on_next_startup": false
  },
  "browser": {
    "show_bookmark_bar": false,
    "signin_promo_skipped": true,
    "signin_promo_show_count": 999,
    "theme": {
      "color_scheme": 2,
      "color_variant": 2,
      "user_color": -1
    }
  },
  "webkit": {
    "webprefs": {
      "preferred_color_scheme": 2
    }
  },
  "distribution": {
    "skip_first_run_ui": true,
    "suppress_first_run_bubble": true,
    "show_welcome_page": false,
    "import_search_engine": false,
    "make_chrome_default": false
  },
  "sync": {
    "requested": false
  },
  "default_search_provider": {
    "enabled": true,
    "name": "Google",
    "keyword": "google.com",
    "search_url": "https://www.google.com/search?q={searchTerms}",
    "favicon_url": "https://www.google.com/favicon.ico",
    "suggest_url": "https://www.google.com/complete/search?client=chrome-omni&gs_ri=chrome-ext&osh=4&q={searchTerms}",
    "encoding": "UTF-8",
    "is_default": true
  }
}
